# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/clinic
# Or MongoDB Atlas:
# MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/clinic

# JWT
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars

# Server
PORT=5001
CLIENT_ORIGIN=http://localhost:3000

# AI – set one or both; fallback advice used if missing or on failure
# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo
# Gemini: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Cloudinary (optional – for prescription PDF uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
